# Copy to `.env` next to your docker-compose invocation and fill in the blanks.
# `.env` is gitignored; never commit secrets.

# --- Postgres (per-node) ----------------------------------------------------
POSTGRES_PASSWORD=replace-me
HRSERV_DB_PASSWORD=replace-me
REPLICATOR_PASSWORD=replace-me

# --- Network ----------------------------------------------------------------
# This node's tailnet IP — what Postgres binds to and what the peer dials.
TAILSCALE_IP=100.64.0.0
# The PEER node's tailnet IP — for primary_conninfo on the replica and for
# pg_hba.conf entries.
PRIMARY_TAILSCALE_IP=100.64.0.0     # only used on the replica
REPLICA_TAILSCALE_IP=100.64.0.0     # only used on the primary

# --- Cloudflare -------------------------------------------------------------
TUNNEL_TOKEN=eyJ...                 # from `cloudflared tunnel token <name>` or dashboard

# --- HRServ runtime ---------------------------------------------------------
# Set via compose; rarely overridden manually:
# DATABASE_URL=postgresql://hrserv:${HRSERV_DB_PASSWORD}@postgres:5432/hrserv
# NODE_ROLE=primary            # primary | replica
# MAX_UPLOAD_BYTES=5242880
# REQUIRE_CF_ACCESS_HEADERS=true
# LOG_LEVEL=INFO
